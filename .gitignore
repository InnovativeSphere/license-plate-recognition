
---


```gitignore
# Virtual environment
.venv/
venv/

# Python cache
__pycache__/
*.pyc
*.pyo

# Secret configuration (contains email/paths)
config.py

# Log files (generated at runtime)
logs/*.json

# Test images (generated by script, but can be recreated)
test_images/*.jpg

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db